{% extends "baseadmin.html.twig" %}

{% block body %}
    
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} mt-2">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

    <br>
{{ form_start(formCategorie) }}

<div class="d-flex justify-content-end gap-2 mb-1">
    {{ form_widget(formCategorie.name, {
        attr: { class: 'form-control', style: 'width: 200px;' }
    }) }}
    {{ form_widget(formCategorie.submit) }}
</div>

{{ form_errors(formCategorie.name) }}
{{ form_end(formCategorie) }}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <caption>liste des catégories</caption>
        <thead>
            <tr>
                <th scope="col">Catégories</th>
                
                <th scope="col">Actions</th>
            </tr>
        </thead>
        
        <tbody class="table-group-divider">
        {% for categorie in categories %}
        <tr>
            <td>{{ categorie.name }}</td>

            <td>
                <a href="{{ path('admin.categorie.suppr', {id:categorie.id}) }}" 
                   class="btn btn-danger mt-1" 
                   onclick="return confirm('Êtes-vous sûr de vouloir supprimer {{categorie.name}} ?');">🗑</a>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
